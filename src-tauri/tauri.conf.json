{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switch Helper",
  "version": "0.1.5",
  "identifier": "com.frank.codex-switch-helper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switch Helper",
        "width": 1120,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFEQzk3QTJDMTBCMDcyM0QKUldROWNyQVFMSHJKclE2OEhHTXd1Sy9FQkljNUl4OU4ranlDM2tmUHQ1RXgwaE11Z0RIbHNCVDMK",
      "endpoints": [
        "https://github.com/frank9306/codex-switch-helper/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
